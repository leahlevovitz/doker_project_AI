{
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "gifts-route": {
        "ClusterId": "product-catalog-cluster",
        "Match": { "Path": "/api/gifts/{**catch-all}" }
      },
      "donors-route": {
        "ClusterId": "product-catalog-cluster",
        "Match": { "Path": "/api/donors/{**catch-all}" }
      },
      "orders-route": {
        "ClusterId": "order-cluster",
        "Match": { "Path": "/api/purchases/{**catch-all}" }
      },
      "inventory-route": {
        "ClusterId": "inventory-cluster",
        "Match": { "Path": "/api/inventory/{**catch-all}" }
      },
      "lottery-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/api/lottery/{**catch-all}" }
      },
      "bff-route": {
        "ClusterId": "bff-cluster",
        "Match": { "Path": "/bff/{**catch-all}" }
      }
    },
    "Clusters": {
      "product-catalog-cluster": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "catalog-1": { "Address": "http://product-catalog-1:8080" },
          "catalog-2": { "Address": "http://product-catalog-2:8080" }
        }
      },
      "order-cluster": {
        "Destinations": {
          "order": { "Address": "http://order:8080" }
        }
      },
      "inventory-cluster": {
        "Destinations": {
          "inventory": { "Address": "http://inventory:8080" }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification": { "Address": "http://notification:8080" }
        }
      },
      "bff-cluster": {
        "Destinations": {
          "bff": { "Address": "http://bff:8080" }
        }
      }
    }
  }
}
